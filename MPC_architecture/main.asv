% % Since we only simulate 3-DOF we need to construct zero arrays for the
% % excluded dimensions, including height, roll and pitch
% z = zeros(length(x),1);
% phi = zeros(length(psi),1);
% theta = zeros(length(psi),1);
% 
% % create object 1: ship (ship1.mat)
% new_object('flypath3d_v2/ship1.mat',[x,y,z,phi,theta,psi],...
% 'model','royalNavy2.mat','scale',(max(max(abs(x)),max(abs(y)))/1000),...
% 'edge',[0 0 0],'face',[0 0 0],'alpha',1,...
% 'path','on','pathcolor',[.89 .0 .27],'pathwidth',2);
% 
% % Object 2: The reference path
% z_p = zeros(length(x_p),1);
% phi_p = zeros(length(x_p),1);
% theta_p = zeros(length(x_p),1);
% psi_p = zeros(length(x_p),1);
% new_object('flypath3d_v2/refpath.mat', ...
%     [x_p, y_p, z_p, phi_p, theta_p, psi_p], 'model', 'royalNavy2.mat', ...
%     'scale', max(max(abs(x), max(abs(y))))/1500, 'edge', [0 0 0], ...
%     'face', [0 .5 1], 'alpha', 1, 'path', 'on', 'pathcolor', [0 .5 1], ...
%     'pathwidth', 2);
% 
% % Plot trajectories 
% flypath('flypath3d_v2/ship1.mat', 'flypath3d_v2/refpath.mat', ...
% 'animate','on','step',1000,...  % step decides animation speed
% 'axis','on','axiscolor',[0 0 0],'color',[1 1 1],...
% 'font','Georgia','fontsize',12,...
% 'view',[-25 35],'window',[900 900],...
% 'xlim', [min(y)-0.1*max(abs(y)),max(y)+0.1*max(abs(y))],... 
% 'ylim', [min(x)-0.1*max(abs(x)),max(x)+0.1*max(abs(x))], ...
% 'zlim', [-max(max(abs(x)),max(abs(y)))/100,max(max(abs(x)),max(abs(y)))/20]); 
% 
% % pathplotter(x, y)
% pathplotterv2(x, y, x_p, y_p)

% % Plot best LOS w vs wo adaptive lookahead
% xgamma           = simdatagamma(:,4);                 % m
% ygamma           = simdatagamma(:,5);                 % m
% xdelta           = simdatadelta(:,4);                 % m
% ydelta           = simdatadelta(:,5);                 % m
% psi_gamma         = simdatagamma(:,6);                 % rad
% psi_deg_gamma     = (180/pi) * psi_gamma;               % deg
% psi_delta         = simdatadelta(:,6);                 % rad
% psi_deg_delta     = (180/pi) * psi_delta;               % deg
% psi_d_gamma       = simdatagamma(:,12);                % rad
% psi_d_deg_gamma   = (180/pi) * psi_d_gamma;             % deg
% psi_d_delta       = simdatadelta(:,12);                % rad
% psi_d_deg_delta   = (180/pi) * psi_d_delta;             % deg
% rgamma           = simdatagamma(:,3);                 % rad/s
% r_deg_gamma       = (180/pi) * rgamma;                 % deg/s
% rdelta           = simdatadelta(:,3);                 % rad/s
% r_deg_delta       = (180/pi) * rdelta;                 % deg/s
% r_d_gamma         =  simdatagamma(:,13);               % rad/s
% r_d_deg_gamma     = (180/pi) * r_d_gamma;               % deg/s
% r_d_delta         =  simdatadelta(:,13);               % rad/s
% r_d_deg_delta     = (180/pi) * r_d_delta;               % deg/s
% delta_c_deg_gamma = (180/pi) * simdatagamma(:,9);      % deg
% delta_c_deg_delta = (180/pi) * simdatadelta(:,9);      % deg
% 
% 
% figure(9);
% hold on;
% % plot(y, x, y_p, x_p, 'linewidth', 2);
% plot(y_p, x_p, 'LineWidth', 1, 'color', 'r') 
% plot(ygamma, xgamma, '--b');
% % plot(ydelta, xdelta, '--g');
% plot(y, x, '--g');
% title('LOS with and without adaptive lookahead distance')
% grid on;
% xlim([-1000,6000]);    % Remember x and y is opposite because NED
% ylim([4000,7500])
% xlabel('East [m]')
% ylabel('North [m]')
% legend('Path', 'With adaptive \Delta', 'Without adaptive \Delta');%, 'Location', 'southeast')
% 
% figure(10)
% figure(gcf)
% subplot(311)
% % plot(tgamma,psi_deg_gamma,tgamma,psi_d_deg_gamma, tdelta,psi_deg_delta,tdelta,psi_d_deg_delta,'linewidth',1);
% % plot(tgamma,psi_deg_gamma, '--b', tdelta,psi_deg_delta, '--g','linewidth',1);
% plot(tgamma,psi_deg_gamma, '--b', t,psi_deg, '--g','linewidth',1);
% title('Yaw angle'); xlabel('Time (s)');  ylabel('Angle (deg)'); 
% % legend('\psi adaptive','\psi_d adaptive','\psi', '\psi_d', 'Location', 'northwest')
% legend('adaptive \Delta','\Delta=3*L_{oa}', 'Location', 'northwest')
% grid on;
% subplot(312)
% % plot(tgamma,r_deg_gamma,tgamma,r_d_deg_gamma, tdelta,r_deg_delta,tdelta,r_d_deg_delta,'linewidth',1);
% % plot(tgamma,r_deg_gamma, '--b', tdelta,r_deg_delta, '--g','linewidth',1);
% plot(tgamma,r_deg_gamma, '--b', t,r_deg, '--g','linewidth',1);
% title('Yaw rate'); xlabel('Time (s)');  ylabel('Angle rate (deg/s)'); 
% % legend('Yaw rate adaptive','desired yaw rate adaptive', 'Yaw rate','desired yaw rate', 'Location', 'northwest')
% legend('adaptive \Delta','\Delta=3*L_{oa}', 'Location', 'northwest')
% grid on;
% subplot(313)
% % plot(tgamma,delta_c_deg_gamma, '--b', tdelta,delta_c_deg_delta, '--g','linewidth',1); axis('equal')
% plot(tgamma,delta_c_deg_gamma, '--b', t,delta_c_deg, '--g','linewidth',1); axis('equal')
% xlim([0, length(delta_c_deg)*h]); ylim([-100, 100]);
% title('Rudder angle'); xlabel('Time (s)'); ylabel('Angle (deg)'); 
% legend('adaptive \Delta','\Delta=3*L_{oa}')
% grid on;